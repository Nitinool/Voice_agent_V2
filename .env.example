# LLM — OpenAI-compatible API（默认走 cix AIhub 网关，deepseek-v4-pro）
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_BASE_URL=https://aihub.cixtech.com/v1
