# LLM — OpenAI-compatible API（默认走 cix AIhub 网关，deepseek-v4-pro）
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_BASE_URL=https://aihub.cixtech.com/v1
LLM_MODEL=deepseek-v4-pro

# STT — Deepgram（nova-3，zh-CN）
DEEPGRAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# TTS — MiMo v2.5（小米 mimo-v2.5-tts，4 中文预置音色）
MIMO_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 可选，若部署在非默认地址
# MIMO_BASE_URL=http://localhost:8000

# 图片生成 — 火山引擎方舟（doubao-seedream 文生图）
ARK_API_KEY=ark-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_IMAGE_MODEL=doubao-seedream-4-5-251128